CREATE TABLE [dbo].[customer]
(
	[cid] INT NOT NULL PRIMARY KEY IDENTITY, 
    [cname] VARCHAR(50) NULL, 
    [mobile] INT NULL, 
    [email] VARCHAR(50) NULL, 
    [password] VARCHAR(50) NULL, 
    [city] VARCHAR(50) NULL
)


CREATE TABLE [dbo].[orders]
(
	[oid] INT NOT NULL PRIMARY KEY IDENTITY, 
    [cid] INT NULL, 
    [pid] INT NULL, 
    [date] DATETIME2 NULL, 
    [quantity] INT NULL
)


CREATE TABLE [dbo].[product]
(
	[pid] INT NOT NULL PRIMARY KEY IDENTITY, 
    [pname] VARCHAR(50) NULL, 
    [brand] VARCHAR(50) NULL, 
    [price] INT NULL, 
    [stock] INT NULL, 
    [isActive] BIT NULL
)

----------------------------------------------------------
CREATE PROCEDURE [dbo].[insertorder]
	@cid int,
	@pid int,
	@quantity int
AS
	insert into orders(cid,pid,date,quantity) values(@cid,@pid,GETDATE(),@quantity);
RETURN 0

----------------------------------------------------------
CREATE PROCEDURE [dbo].[update]
	@oid int,
	@quantity int
AS
	update orders set quantity=@quantity where oid=@oid;
RETURN 0

----------------------------------------------------------
CREATE PROCEDURE [dbo].[deleteorder]
	@oid int
AS
	delete from orders where oid=@oid;
RETURN 0

----------------------------------------------------------
CREATE PROCEDURE [dbo].[gettotal]
	@cid int
AS
	SELECT sum(price*quantity) as total from orders o
	join product p on o.pid=p.pid where o.cid=@cid;
RETURN 0
