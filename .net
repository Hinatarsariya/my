website.controller

using external1_Batch_1.Models;
using Microsoft.AspNetCore.Mvc;
using System.Data;
using System.Data.SqlClient;
using System.Security.Cryptography;


namespace external1_Batch_1.Controllers
{
    
    public class websiteController : Controller
    {
        SqlConnection con = new SqlConnection("Data Source=(LocalDB)\\MSSQLLocalDB;AttachDbFilename=C:\\Users\\Admin\\Documents\\external1_Batch_1.mdf;Integrated Security=True;Connect Timeout=30");
        SqlCommand cmd =new SqlCommand();
        SqlDataAdapter da = new SqlDataAdapter();
        DataTable dt = new DataTable();
        public IActionResult Index()
        {
            return View();
        }
        [HttpGet]
        public IActionResult login()
        {
            return View();
        }
        [HttpPost]
        public IActionResult login(customer c)
        {
            con.Open();

            dt=new DataTable();

            da = new SqlDataAdapter("select *from customer where email='" + c.email + "' and password='" + c.password + "'", con);
            da.Fill(dt);

            if(dt.Rows.Count > 0 )
            {
                int cid = Convert.ToInt32(dt.Rows[0]["cid"]);
                string cname = dt.Rows[0]["cname"].ToString();

                HttpContext.Session.SetInt32("customer_id", cid);

                Response.Cookies.Append("customer_name", cname, new CookieOptions
                {
                    Expires = DateTime.Now.AddMinutes(60),
                    IsEssential = true,
                    HttpOnly = true
                });

                return RedirectToAction("welcome");
            }
            else
            {
                ViewBag.error = "Invalid Username Password";
                return RedirectToAction("login");
            }

                return View();
        }
        public IActionResult welcome()
        {
            if(!Request.Cookies.TryGetValue("customer_name",out string cname))
            {
                return RedirectToAction("login");
            }
            ViewBag.customer_name = cname;
                return View();
        }


        public IActionResult display_product()
        {
            con.Open();

            dt = new DataTable();

            da = new SqlDataAdapter("select *from product", con);
            da.Fill(dt);

            if(dt.Rows.Count > 0 )
            {
                return View(dt);
            }
            return View();
        }

        public IActionResult order_page(int pid)
        {
            con.Open();

            dt = new DataTable();

            da = new SqlDataAdapter("select *from product where pid="+pid+"", con);
            da.Fill(dt);

            if (dt.Rows.Count > 0)
            {
                return View(dt);
            }
            return View();
        }
        [HttpPost]
        public IActionResult order_page(int pid,int quantity)
        {
            con.Open();

            dt = new DataTable();

            int cid = Convert.ToInt32(HttpContext.Session.GetInt32("customer_id"));

            cmd = new SqlCommand("insertorder", con);
            cmd.CommandType = CommandType.StoredProcedure;

            cmd.Parameters.AddWithValue("@cid", cid);
            cmd.Parameters.AddWithValue("@pid", pid);
            cmd.Parameters.AddWithValue("@quantity", quantity);

            cmd.ExecuteNonQuery();
            return RedirectToAction("myorder");
        }

        public IActionResult myorder()
        {

            int cid = Convert.ToInt32(HttpContext.Session.GetInt32("customer_id"));


            con.Open();
            dt = new DataTable();

            da = new SqlDataAdapter("gettotal", con);
            da.SelectCommand.CommandType = CommandType.StoredProcedure;

            da.SelectCommand.Parameters.AddWithValue("@cid", cid);

            da.Fill(dt);

            int totalamount = Convert.ToInt32(dt.Rows[0]["total"]);
            ViewBag.totalamount = totalamount;
            con.Close();


            con.Open();

            dt = new DataTable();



            da = new SqlDataAdapter("select *from orders where cid=" + cid + "", con);
            da.Fill(dt);

            if (dt.Rows.Count > 0)
            {
                return View(dt);
            }
            con.Close();
            return View();
           
        }

        public IActionResult update(int oid,int pid)
        {
            HttpContext.Session.SetInt32("order_id", oid);
            return View();
        }
        [HttpPost]
        public IActionResult update(int quantity)
        {
            con.Open();

            dt = new DataTable();

            int oid = Convert.ToInt32(HttpContext.Session.GetInt32("order_id"));

            cmd = new SqlCommand("update", con);
            cmd.CommandType = CommandType.StoredProcedure;

            cmd.Parameters.AddWithValue("@oid", oid);
            cmd.Parameters.AddWithValue("@quantity", quantity);

            cmd.ExecuteNonQuery();
            return RedirectToAction("myorder");

            return View();
        }

        public IActionResult delete(int oid)
        {
            con.Open();


            cmd = new SqlCommand("deleteorder", con);
            cmd.CommandType = CommandType.StoredProcedure;

            cmd.Parameters.AddWithValue("@oid", oid);
           

            cmd.ExecuteNonQuery();
            return RedirectToAction("myorder");
        }



        public IActionResult logout()
        {
            HttpContext.Session.Clear();
            return RedirectToAction("login");
        }
    }
}
