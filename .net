display_product.cshtml

@using System.Data
@using external1_Batch_1.Models
@model DataTable


<center>
    <h3>Products</h3>
</center>


<hr/>

<html>

    <head></head>

    <body>

        <table border="3" class="table table-bordered table-striped table-hover">

            <tr>
                @foreach(DataColumn dc in Model.Columns)
                {
                    <th>@dc.ColumnName</th>
                }
                <th>Action</th>
        </tr>


        @foreach(DataRow dr in Model.Rows)
        {
            <tr>

                <td>@dr[0]</td>
                 <td>@dr[1]</td>
                <td>@dr[2]</td>
                <td>@dr[3]</td>
                <td>@dr[4]</td>
                <td>@dr[5]</td>

                <td>
                    @if(Convert.ToInt32(@dr[4])>0 && @dr[5].ToString()=="True")
                    {
                        <a asp-action="order_page" asp-controller="website" asp-route-pid="@dr[0]">Order Now</a>
                    }
                </td>
            </tr>
        }



        </table>
    </body>
</html>
