 public IActionResult booktour(int tourid)
 {
     ViewBag.tourid = tourid;
     return View();
 }
 [HttpPost]
 public IActionResult booktour(int tourid, int person)
 {
     int customerid = (int)(HttpContext.Session.GetInt32("customerid"));
     con.Open();
     adapter = new SqlDataAdapter("select Price from Tour where Tour_Id = " + tourid + "", con);
     adapter.Fill(dt);
     int price = (int)(dt.Rows[0]["Price"]);
     int amt = person * price;
     cmd = new SqlCommand("InsertBookingDetails", con);
     cmd.CommandType = CommandType.StoredProcedure;
     cmd.Parameters.AddWithValue("@customerid", customerid);
     cmd.Parameters.AddWithValue("@tourid", tourid);
     cmd.Parameters.AddWithValue("@person", person);
     cmd.Parameters.AddWithValue("@amount", amt);
     cmd.ExecuteNonQuery();
     cmd = new SqlCommand("update Tour set Is_Available = 'no' where Tour_Id = " + tourid + "", con);
     cmd.ExecuteNonQuery();
     adapter = new SqlDataAdapter("select * from Tour", con);
     adapter.Fill(dt);
     if (dt.Rows.Count > 0)
     {
         return RedirectToAction("displaytourpackage", dt);
     }
     else
     {
         return View();
     }
     con.Close();
 }

