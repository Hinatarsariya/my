[HttpPost]
public IActionResult searchtourpackage(int minday, int maxday)
{
    con.Open();
    cmd = new SqlCommand("SearchTourPackage", con);
    cmd.CommandType = CommandType.StoredProcedure;
    cmd.Parameters.AddWithValue("@minday", minday);
    cmd.Parameters.AddWithValue("@maxday", maxday);
    adapter = new SqlDataAdapter(cmd);
    adapter.Fill(dt);
    if (dt.Rows.Count > 0)
    {
        return View("searchresult", dt);
    }
    else
    {
        return View();
    }
}

