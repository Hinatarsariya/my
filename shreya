using System.Data;
using System.Data.SqlClient;

SqlConnection con = new SqlConnection("C:\\USERS\\DELL\\DOCUMENTS\\TOURTRAVELDB.MDF");
SqlCommand cmd = new SqlCommand();
SqlDataAdapter adapter = new SqlDataAdapter();
DataTable dt = new DataTable();



public IActionResult login(string email, string password)
{
    con.Open();
    adapter = new SqlDataAdapter("select * from Customer where Email_Id = '" + email + "' and Password = '" + password + "'", con);
    adapter.Fill(dt);
    if (dt.Rows.Count > 0)
    {
        HttpContext.Session.SetString("email", email);
        HttpContext.Session.SetString("password", password);
        HttpContext.Session.SetInt32("customerid", (int)Convert.ToInt32(dt.Rows[0]["Customer_Id"]));
        //ViewBag.msg = "Valid User.";
        return RedirectToAction("displaytourpackage");
    }
    else
    {
        ViewBag.msg = "Invalid Credentials.";
        return View();
    }
}


